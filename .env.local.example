# Скопіюй у .env.local (не комітиться, .env* в .gitignore) і заповни своїм ключем.

# Ключ Gemini з aistudio.google.com/apikey
GEMINI_API_KEY=

# "mock" — використовувати захардкоджені приклади задач замість реального
# виклику AI (зручно для розробки без ключа). Будь-яке інше значення
# (або відсутність змінної) — реальний виклик Gemini.
AI_PROVIDER=gemini
